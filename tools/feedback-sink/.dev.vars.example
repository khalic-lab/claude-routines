# Copy to .dev.vars (gitignored) for `wrangler dev`, and set the same via
# `wrangler secret put` for production. See README.md.

# Bearer for /drain and /ack — a REAL secret (lives only on the Mac bridge + Worker).
FEEDBACK_TOKEN=replace-with-a-long-random-string

# Shared site key the widget sends on /submit + /propose (NOT a strong secret — visitors
# type it into the unlock modal). REQUIRED: the Worker fails closed, returning 403 on
# every public write while this is unset.
WIDGET_KEY=

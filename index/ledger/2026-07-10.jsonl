{"ev": "seen", "ts": "2026-07-10T10:09:16Z", "actor": "news", "story": {"id": "st-0d74c289953e", "date": "2026-07-10", "stream": "news", "headline": "Strasbourg court rules Switzerland violated Le Courrier's press freedom", "summary": "The European Court of Human Rights found Switzerland breached the Geneva daily Le Courrier's free-expression rights in a defamation dispute with businessman Jean Claude Gandur.", "url": "https://www.letemps.ch/articles/la-cedh-condamne-la-suisse-pour-violation-de-la-liberte-d-expression-du-journal-le-courrier", "source_domain": "letemps.ch", "tier": "T2", "tags": [], "topics": ["switzerland", "politics"], "importance": 2, "display_body": "The European Court of Human Rights (ECtHR — the Strasbourg court that enforces the European Convention on Human Rights) found that Switzerland breached the free-expression rights of the Geneva daily Le Courrier, in a long-running defamation dispute pitting the paper against businessman and art collector Jean Claude Gandur. Swiss courts had penalised the paper over its reporting; Strasbourg held that sanction disproportionate under Article 10 (freedom of expression).", "why": "An ECtHR condemnation obliges Switzerland to align its defamation case-law with Convention standards, and strengthens the hand of Swiss outlets reporting critically on wealthy public figures.", "thread_id": "2026-07-10-news-strasbourg-court-rules-switzerland-violated-le-c", "first_seen_date": "2026-07-10", "event_date": "2026-07-09", "embedding_model": "bge-m3", "emb": "", "status": "settled", "first_seen": "2026-07-10T10:09:16Z", "updated": "2026-07-10T10:09:16Z", "legacy_ids": ["2026-07-10-news-strasbourg-court-rules-switzerland-violated-le-c"], "editions": ["2026-07-10-news"], "origin": "writer:news", "streams": ["news"]}}
{"ev": "publish", "ts": "2026-07-10T10:09:16Z", "actor": "news", "id": "st-0d74c289953e", "edition": "2026-07-10-news", "fields": {"display_body": "The European Court of Human Rights (ECtHR — the Strasbourg court that enforces the European Convention on Human Rights) found that Switzerland breached the free-expression rights of the Geneva daily Le Courrier, in a long-running defamation dispute pitting the paper against businessman and art collector Jean Claude Gandur. Swiss courts had penalised the paper over its reporting; Strasbourg held that sanction disproportionate under Article 10 (freedom of expression).", "why": "An ECtHR condemnation obliges Switzerland to align its defamation case-law with Convention standards, and strengthens the hand of Swiss outlets reporting critically on wealthy public figures.", "importance": 2, "status": "settled"}}
{"ev": "seen", "ts": "2026-07-10T10:09:16Z", "actor": "news", "story": {"id": "st-079bae6e7690", "date": "2026-07-10", "stream": "news", "headline": "Albula assembly approves plan to relocate rockslide-threatened Brienz", "summary": "The Graubunden municipality of Albula/Alvra approved a relocation plan for the village of Brienz, threatened by an ongoing slope collapse.", "url": "https://www.letemps.ch/articles/face-aux-eboulements-a-brienz-un-plan-de-relocalisation-approuve-par-l-assemblee-communale-d-albula", "source_domain": "letemps.ch", "tier": "T2", "tags": [], "topics": ["switzerland"], "importance": 2, "display_body": "The Graubunden municipal assembly of Albula/Alvra approved a relocation plan for the village of Brienz (Brinzauls), which sits below a slowly collapsing mountainside that has forced repeated evacuations. The vote moves the long-debated managed-retreat option from study toward implementation.", "why": "Brienz is Switzerland's clearest test case for planned relocation of an entire community ahead of a geological disaster, a template other Alpine villages facing destabilised slopes are watching.", "thread_id": "2026-07-10-news-albula-assembly-approves-plan-to-relocate-rocksl", "first_seen_date": "2026-07-10", "event_date": "2026-07-10", "embedding_model": "bge-m3", "emb": "", "status": "settled", "first_seen": "2026-07-10T10:09:16Z", "updated": "2026-07-10T10:09:16Z", "legacy_ids": ["2026-07-10-news-albula-assembly-approves-plan-to-relocate-rocksl"], "editions": ["2026-07-10-news"], "origin": "writer:news", "streams": ["news"]}}
{"ev": "publish", "ts": "2026-07-10T10:09:16Z", "actor": "news", "id": "st-079bae6e7690", "edition": "2026-07-10-news", "fields": {"display_body": "The Graubunden municipal assembly of Albula/Alvra approved a relocation plan for the village of Brienz (Brinzauls), which sits below a slowly collapsing mountainside that has forced repeated evacuations. The vote moves the long-debated managed-retreat option from study toward implementation.", "why": "Brienz is Switzerland's clearest test case for planned relocation of an entire community ahead of a geological disaster, a template other Alpine villages facing destabilised slopes are watching.", "importance": 2, "status": "settled"}}
{"ev": "seen", "ts": "2026-07-10T10:09:16Z", "actor": "news", "story": {"id": "st-730fe6e985a4", "date": "2026-07-10", "stream": "news", "headline": "July drought bites Swiss farms and forests", "summary": "An unusually early summer drought and heatwave are stressing Swiss agriculture, cutting livestock yields and browning forests.", "url": "https://www.srf.ch/news/schweiz/landwirtschaft-und-klimawandel-bauern-leiden-unter-der-trockenheit", "source_domain": "srf.ch", "tier": "T2", "tags": [], "topics": ["switzerland", "economy"], "importance": 2, "display_body": "An unusually early summer drought and heatwave are stressing Swiss agriculture: farmers report livestock eating less in the heat — cutting weight gain and milk yields — while dry, prematurely browning forests (\"autumn in July\") add fire and dieback risk.", "why": "", "thread_id": "2026-07-10-news-july-drought-bites-swiss-farms-and-forests", "first_seen_date": "2026-07-10", "event_date": "2026-07-10", "embedding_model": "bge-m3", "emb": "", "status": "settled", "first_seen": "2026-07-10T10:09:16Z", "updated": "2026-07-10T10:09:16Z", "legacy_ids": ["2026-07-10-news-july-drought-bites-swiss-farms-and-forests"], "editions": ["2026-07-10-news"], "origin": "writer:news", "streams": ["news"]}}
